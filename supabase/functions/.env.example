# Local Supabase Edge Function development only.
# Never commit real values. Hosted secrets are configured with `supabase secrets set`.

MARKETING_FUNCTION_SECRET=replace-with-a-long-random-secret
APP_PUBLIC_URL=https://your-velliqo-domain.example

# Resend email delivery
RESEND_API_KEY=re_xxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx
EMAIL_FROM=Velliqo <notifications@your-verified-domain.example>
MARKETING_TEST_EMAIL=owner-test@example.com

# Twilio SMS delivery (optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxx
# Use TWILIO_FROM_NUMBER instead when no Messaging Service is configured.
TWILIO_FROM_NUMBER=+35700000000
TWILIO_STATUS_CALLBACK_URL=https://PROJECT_REF.supabase.co/functions/v1/twilio-marketing-webhook
MARKETING_TEST_PHONE=+35700000000
